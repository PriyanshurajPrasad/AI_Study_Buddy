{
  "name": "ai-study-buddy-backend",
  "version": "1.0.0",
  "description": "AI Study Buddy - Smart Learning Assistant Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "check-port": "node utils/portUtils.js",
    "dev:check": "node check-port.js && nodemon server.js",
    "kill-port": "node -e \"require('./utils/portUtils').killProcessUsingPort(5000)\"",
    "port-info": "node -e \"require('./utils/portUtils').logPortInfo(5000)\"",
    "detect-port": "node utils/autoDetectBackendPort.js",
    "configure-frontend": "node utils/autoDetectBackendPort.js"
  },
  "keywords": [
    "ai",
    "study",
    "learning",
    "gemini",
    "education"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.16.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "groq-sdk": "^1.2.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.12.0",
    "mongoose": "^8.0.3",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.4"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
